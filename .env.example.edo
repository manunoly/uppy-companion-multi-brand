# ===========================================
# COMPANION PLATFORM — edo (Entourage) single-brand shell
# ===========================================
#
# PLACEHOLDERS ONLY. Every value below is either a non-secret example or a
# `changeme`/`<...>` placeholder — never paste a real key/token/secret into
# this file. Fill the real values into your own untracked `.env` (or Railway
# service variables), never here.
#
# This is a companion doc to the main `.env.example` (full reference, all
# brands + both SECRETS_SOURCE modes). This file is scoped to booting a
# single-brand `edo`-only Companion shell (BRAND_FORCE=edo) — edo is servable
# today (companionHosts is non-empty in registry.ts) and this gives parity
# with today's live edo configuration.

# ===========================================
# Server (global, brand-independent) — src/config/env.schema.ts
# ===========================================
COMPANION_PORT=3020
COMPANION_BIND_HOST=0.0.0.0
# Public hostname:port Companion reports at boot (src/index.ts). Does NOT
# drive brand resolution or OAuth redirect_uri — that's each brand's
# `companionUrl` (registry.ts). localhost is fine for local dev.
COMPANION_HOST=localhost:3020
COMPANION_PROTOCOL=http
# REQUIRED, >= 16 chars or the server refuses to boot (env.schema.ts). Shared
# across every brand — do not use a real secret here.
COMPANION_SECRET=changeme-min-16-chars

# Local scratch dir for in-flight uploads (brand-independent).
COMPANION_FILE_PATH=/tmp/

# Gates the detailed view of GET /api/brands?key=... (masked id/displayName
# view is available with no key at all). Optional — omit to disable it.
HEALTH_CHECK_KEY=changeme

# Shared state across replicas: readiness checks, express-session's OAuth
# store, the whoami cache/circuit-breaker, rate-limit counters. Falls back to
# a local dev default if omitted.
# REDIS_URL=redis://localhost:6379

# Rate limiting (express-rate-limit + rate-limit-redis). Two independent,
# fully optional limiters:
#   - RATE_LIMIT_*        : per brand+user/IP, mounted on /uppy and /api/* only.
#   - RATE_LIMIT_GLOBAL_* : per-IP, global, ahead of express-session/attachUser
#     — also bounds `/`, OAuth, `/s3`, `/api/brands`. Exempts /api/healthz and
#     /api/readyz (continuously polled by the orchestrator).
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# RATE_LIMIT_GLOBAL_WINDOW_MS=60000
# RATE_LIMIT_GLOBAL_MAX=600

# ===========================================
# BRAND SELECTION & OVERRIDE (src/modules/brand/{registry,identity,detect}.ts)
# ===========================================
# Routes every request to `edo` regardless of the inbound Host — the
# single-brand dev shell this file is for.
BRAND_FORCE=edo

# Optional JSON override, merged over the registry's base `auth` — ONLY these
# STRING fields may be overridden: whoamiUrl, signInUrl, signOutUrl,
# sessionCookieName. Everything else (kind, whoamiAllowedHosts,
# requireVerifiedEmail, assets.s3Prefix, companionHosts, s3, providers, ...)
# is CODE-ONLY and PROTECTED — any attempt to override it is dropped silently
# with a logger.warn (identity.ts PROTECTED_AUTH_KEYS). A malformed JSON value
# here falls back to the registry default with NO log at all — run
# `npx tsx scripts/verify-brand-config.ts` after editing it.
#
# Points to STAGE instead of the registry's PRODUCTION defaults. Not secret
# (plain URLs). Registry base (production) values, for reference:
#   whoamiUrl  = https://edonext-app.entourageyearbooks.com/api/user
#   signInUrl  = https://edonext.entourageyearbooks.com/login
#   signOutUrl = https://edonext-app.entourageyearbooks.com/logout
#   cookie     = auth_session   (companionHosts covers prod+stage, code-only)
EDO_BRAND_OVERRIDE={"auth":{"whoamiUrl":"https://edonext-app.stage.entourageyearbooks.com/api/user","signInUrl":"https://edonext.stage.entourageyearbooks.com/login","signOutUrl":"https://edonext-app.stage.entourageyearbooks.com/logout","sessionCookieName":"auth_session_stage"}}

# ===========================================
# PER-BRAND SECRETS (src/lib/secrets.ts#loadBrandSecrets) — SECRETS_SOURCE=env
# ===========================================
SECRETS_SOURCE=env

# -------------------------------------------------------------------
# edo S3 — real bucket/region (bucket/region are not secret; keys are).
# assets.s3Prefix is '' in the registry: edo's own S3 layout is
# 'original/{userId}/...' directly, no 'brands/edo/' prefix.
# -------------------------------------------------------------------
EDO_S3_BUCKET=entourage-uploads
EDO_S3_REGION=us-east-1
# SECRET. Under SECRETS_SOURCE=env these are REQUIRED (Railway has no instance
# IAM role) unless you rely on the global AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY
# fallback instead (see the base .env.example).
EDO_S3_ACCESS_KEY=changeme
EDO_S3_SECRET_KEY=changeme
EDO_S3_ACCELERATE_ENDPOINT=false

# No S2S ingest seam for edo: `edo`'s registry entry has no `ingest` block —
# its backend is edonext, not capsule, so there is no
# EDO_INGEST_TOKEN/tokenEnv to set. N/A until edo (if ever) adopts the same
# ingest-callback seam abe uses (P1-C3/P1-G4).

# -------------------------------------------------------------------
# edo OAuth — edo's registry `upload.plugins` is `['Facebook', 'Url']`
# ('Url' needs no OAuth credentials). Facebook is wired once BOTH _KEY and
# _SECRET below are set. ALL SECRET unless noted.
# -------------------------------------------------------------------
EDO_FACEBOOK_KEY=changeme
EDO_FACEBOOK_SECRET=changeme

# Other providers available to edo (optional — only add if edo's registry
# `upload.plugins` grows to include them):
# EDO_DROPBOX_KEY=changeme
# EDO_DROPBOX_SECRET=changeme
#
# Google: wired once EDO_GOOGLE_CLIENT_ID is set; the rest is optional.
# CLIENT_ID/APP_ID are public (visible in the browser) — CLIENT_SECRET and the
# API keys are secret. edo does not use Google today.
# EDO_GOOGLE_CLIENT_ID=000000000000-xxxxxxxx.apps.googleusercontent.com
# EDO_GOOGLE_APP_ID=000000000000
# EDO_GOOGLE_CLIENT_SECRET=changeme
# EDO_GOOGLE_DRIVE_API_KEY=changeme
# EDO_GOOGLE_PHOTOS_API_KEY=changeme
