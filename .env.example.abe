# ===========================================
# COMPANION PLATFORM — abe (Abeduls) single-brand shell
# ===========================================
#
# PLACEHOLDERS ONLY. Every value below is either a non-secret example or a
# `changeme`/`<...>` placeholder — never paste a real key/token/secret into
# this file. Fill the real values into your own untracked `.env` (or Railway
# service variables), never here.
#
# This is a companion doc to the main `.env.example` (full reference, all
# brands + both SECRETS_SOURCE modes). This file is scoped to booting a
# single-brand `abe`-only Companion shell (BRAND_FORCE=abe). See CLAUDE.md
# ("Architecture" / "Brand resolution & config") for the 3-layer model:
# code-only registry (registry.ts) + <SLUG>_BRAND_OVERRIDE + per-brand secrets
# (secrets.ts).

# ===========================================
# Server (global, brand-independent) — src/config/env.schema.ts
# ===========================================
COMPANION_PORT=3020
COMPANION_BIND_HOST=0.0.0.0
# Public hostname:port Companion reports at boot (src/index.ts). Does NOT
# drive brand resolution or OAuth redirect_uri — that's each brand's
# `companionUrl` (registry.ts). localhost is fine for local dev.
COMPANION_HOST=localhost:3020
COMPANION_PROTOCOL=http
# REQUIRED, >= 16 chars or the server refuses to boot (env.schema.ts). Shared
# across every brand — do not use a real secret here.
COMPANION_SECRET=changeme-min-16-chars

# Local scratch dir for in-flight uploads (brand-independent).
COMPANION_FILE_PATH=/tmp/

# Gates the detailed view of GET /api/brands?key=... (masked id/displayName
# view is available with no key at all). Optional — omit to disable it.
HEALTH_CHECK_KEY=changeme

# Shared state across replicas: readiness checks, express-session's OAuth
# store, the whoami cache/circuit-breaker, rate-limit counters. Falls back to
# a local dev default if omitted.
# REDIS_URL=redis://localhost:6379

# Rate limiting (express-rate-limit + rate-limit-redis). Two independent,
# fully optional limiters:
#   - RATE_LIMIT_*        : per brand+user/IP, mounted on /uppy and /api/* only.
#   - RATE_LIMIT_GLOBAL_* : per-IP, global, ahead of express-session/attachUser
#     — also bounds `/`, OAuth, `/s3`, `/api/brands`. Exempts /api/healthz and
#     /api/readyz (continuously polled by the orchestrator).
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# RATE_LIMIT_GLOBAL_WINDOW_MS=60000
# RATE_LIMIT_GLOBAL_MAX=600

# ===========================================
# BRAND SELECTION & OVERRIDE (src/modules/brand/{registry,identity,detect}.ts)
# ===========================================
# Routes every request to `abe` regardless of the inbound Host — the
# single-brand dev shell this file is for. Must name a SERVABLE slug
# (assertBrandForceIsServable, detect.ts) — abe IS servable today
# (companionHosts is non-empty in registry.ts, P1-C1).
BRAND_FORCE=abe

# Optional JSON override, merged over the registry's base `auth` — ONLY these
# STRING fields may be overridden: whoamiUrl, signInUrl, signOutUrl,
# sessionCookieName. Everything else (kind, whoamiAllowedHosts,
# requireVerifiedEmail, assets.s3Prefix, companionHosts, s3, providers, ...)
# is CODE-ONLY and PROTECTED — any attempt to override it is dropped silently
# with a logger.warn (identity.ts PROTECTED_AUTH_KEYS). A malformed JSON value
# here falls back to the registry default with NO log at all — run
# `npx tsx scripts/verify-brand-config.ts` after editing it.
#
# IMPORTANT: designer/node-socket (abeduls3 monorepo) and this Companion MUST
# point at the SAME whoami/sign-in endpoints for a given environment, or a
# user can authenticate in one service and fail in the other.
#
# Registry base (production) values, for reference:
#   whoamiUrl  = https://abeduls.com/api/user
#   signInUrl  = https://abeduls.com/sign-in
#   cookie     = abes_session
# ABE_BRAND_OVERRIDE={"auth":{"whoamiUrl":"https://<stage-host>/api/user","signInUrl":"https://<stage-host>/sign-in","sessionCookieName":"abes_session"}}

# ===========================================
# PER-BRAND SECRETS (src/lib/secrets.ts#loadBrandSecrets) — SECRETS_SOURCE=env
# ===========================================
SECRETS_SOURCE=env

# -------------------------------------------------------------------
# abe S3 (bucket shared 1:1 with capsule — assets.s3Prefix is '' in the
# registry, so keys land at 'original/{userId}/...' with no 'brands/abe/'
# prefix, same layout capsule itself writes).
# -------------------------------------------------------------------
# CRITICAL: ABE_S3_BUCKET MUST equal capsule's own bucket
# (apps/capsule AWS_S3_BUCKET_NAME / legacy AWS_BUCKET_NAME, abeduls3 monorepo,
# P1-G1) — this is a SHARED bucket, not a Companion-owned one. Using a
# different bucket here silently breaks the abe upload -> capsule ingest flow
# (the ingest callback expects the object to already be in ITS bucket).
ABE_S3_BUCKET=changeme-must-equal-capsule-AWS_S3_BUCKET_NAME
ABE_S3_REGION=us-east-1
# SECRET. Under SECRETS_SOURCE=env these are REQUIRED (Railway has no instance
# IAM role) unless you rely on the global AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY
# fallback instead (see the base .env.example).
ABE_S3_ACCESS_KEY=changeme
ABE_S3_SECRET_KEY=changeme
# IAM NOTE (owner decision X-1): the IAM principal behind these keys needs
# PutObject + every multipart verb (CreateMultipartUpload, UploadPart,
# CompleteMultipartUpload, AbortMultipartUpload, ListParts) + HeadObject, plus
# bucket-level ListBucket/HeadBucket for the readiness check — NEVER
# DeleteObject. Companion never deletes objects; scope the policy accordingly.
ABE_S3_ACCELERATE_ENDPOINT=false

# -------------------------------------------------------------------
# abe S2S ingest seam (P1-C3/P1-G4) — capsule's internal media-ingest
# endpoint. `ingest.url` is CODE (registry.ts: `https://abeduls.com/api/
# internal/media/ingest`), NOT an env var — it is resolved + SSRF-gated at
# call time against abe's whoamiAllowedHosts (identity.ts
# resolveValidatedIngestTarget). Only the Bearer token is env-configured here.
# -------------------------------------------------------------------
# SECRET — same value as the abeduls3 monorepo's INTERNAL_AUTH_TOKEN (S2S
# shared secret, see abeduls3/CLAUDE.md "Internal service-to-service (S2S)
# auth"). Sent as `Authorization: Bearer <value>` on the ingest callback.
ABE_INGEST_TOKEN=changeme

# -------------------------------------------------------------------
# abe OAuth (Phase 2 — DEFERRED). abe's registry `upload.plugins` is empty
# today (P1-C1) — none of these are required to serve local upload via
# S3/multipart. Left commented as a reference for when Phase 2 wires an
# OAuth-backed source into abe's Uppy Dashboard. ALL SECRET unless noted.
# -------------------------------------------------------------------
# ABE_DROPBOX_KEY=changeme
# ABE_DROPBOX_SECRET=changeme
#
# Google: wired once ABE_GOOGLE_CLIENT_ID is set; the rest is optional.
# CLIENT_ID/APP_ID are public (visible in the browser) — CLIENT_SECRET and the
# API keys are secret. ABE_GOOGLE_PHOTOS_API_KEY is Picker-only (no OAuth
# scope needed beyond the API key itself).
# ABE_GOOGLE_CLIENT_ID=000000000000-xxxxxxxx.apps.googleusercontent.com
# ABE_GOOGLE_APP_ID=000000000000
# ABE_GOOGLE_CLIENT_SECRET=changeme
# ABE_GOOGLE_DRIVE_API_KEY=changeme
# ABE_GOOGLE_PHOTOS_API_KEY=changeme
#
# ABE_FACEBOOK_KEY=changeme
# ABE_FACEBOOK_SECRET=changeme
