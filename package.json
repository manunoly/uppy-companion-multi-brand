{
    "name": "uppy-companion-multi-brand",
    "version": "0.1.0",
    "author": "Manuel Almaguer",
    "website": "https://manuel-almaguer.web.app",
    "license": "MIT",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "main": "dist/index.js",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json && node scripts/build-assets.mjs",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "biome check . --formatter-enabled=false --assist-enabled=false",
        "format": "biome format --write ."
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1079.0",
        "@aws-sdk/client-secrets-manager": "^3.1079.0",
        "@aws-sdk/s3-request-presigner": "^3.1079.0",
        "@uppy/companion": "^6.2.1",
        "compression": "^1.8.1",
        "connect-redis": "^8.1.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.2.3",
        "express": "^4.22.1",
        "express-rate-limit": "^7.5.1",
        "express-session": "^1.19.0",
        "helmet": "^8.2.0",
        "ioredis": "^5.8.2",
        "pino": "^9.14.0",
        "pino-http": "^10.5.0",
        "rate-limit-redis": "^4.3.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^4.17.25",
        "@types/express-session": "^1.18.2",
        "@types/ioredis-mock": "^8.2.7",
        "@types/node": "^25.0.10",
        "@types/supertest": "^7.2.0",
        "@uppy/aws-s3": "^5.1.0",
        "@uppy/box": "^4.1.0",
        "@uppy/compressor": "^3.1.0",
        "@uppy/core": "^5.2.0",
        "@uppy/dashboard": "^5.1.1",
        "@uppy/dropbox": "^5.1.0",
        "@uppy/facebook": "^5.1.0",
        "@uppy/google-drive": "^5.1.0",
        "@uppy/google-drive-picker": "^1.1.1",
        "@uppy/google-photos-picker": "^1.1.0",
        "@uppy/image-editor": "^4.2.0",
        "@uppy/instagram": "^5.1.0",
        "@uppy/onedrive": "^5.1.0",
        "@uppy/thumbnail-generator": "^5.1.0",
        "@uppy/unsplash": "^5.1.0",
        "@uppy/url": "^5.1.0",
        "@uppy/zoom": "^4.1.0",
        "@vitest/coverage-v8": "^4.1.5",
        "aws-sdk-client-mock": "^4.1.0",
        "esbuild": "^0.28.1",
        "ioredis-mock": "^8.13.1",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.5"
    }
}