# ===========================================
# COMPANION PLATFORM - Environment Variables
# ===========================================

# Server Configuration
COMPANION_PORT=3020
COMPANION_BIND_HOST=0.0.0.0
COMPANION_HOST=localhost:3020
COMPANION_PROTOCOL=http
COMPANION_SECRET=your-secret-at-least-16-chars

# File storage
COMPANION_FILE_PATH=/tmp/

# Brands (comma-separated slugs)
# The first brand listed is the DEFAULT brand.
COMPANION_BRANDS=default,another-brand

# ===========================================
# PER-BRAND AUTHENTICATION
# ===========================================
# URL that validates tokens. Returns 200 + user JSON if authenticated.
# DEFAULT_AUTH_URL=https://api.example.com/api/user

# ===========================================
# AWS S3 CONFIGURATION
# ===========================================
AWS_BUCKET_NAME=your-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# COMPANION_AWS_ACCELERATE_ENDPOINT=false

# ===========================================
# OAUTH PROVIDERS
# ===========================================

# --- Dropbox ---
# Console: https://www.dropbox.com/developers/apps
# Redirect URI: http://localhost:3020/{brand}/connect/dropbox/callback
COMPANION_DROPBOX_KEY=your-dropbox-app-key
COMPANION_DROPBOX_SECRET=your-dropbox-app-secret

# --- Facebook / Instagram ---
# Console: https://developers.facebook.com/apps/
# Redirect URIs: 
#   http://localhost:3020/{brand}/connect/facebook/callback
#   http://localhost:3020/{brand}/connect/instagram/callback
COMPANION_FACEBOOK_KEY=your-facebook-app-id
COMPANION_FACEBOOK_SECRET=your-facebook-app-secret

# --- Google Drive / Google Photos ---
# Console: https://console.cloud.google.com/
# Enable: Google Drive API, Google Photos Library API
# Redirect URI: http://localhost:3020/{brand}/connect/google/callback
COMPANION_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
COMPANION_GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# Picker credentials (public)
COMPANION_GOOGLE_DRIVE_API_KEY=AIzaSyour-google-drive-picker-api-key
COMPANION_GOOGLE_PHOTOS_API_KEY=AIzaSyour-google-photos-picker-api-key
COMPANION_GOOGLE_APP_ID=your-google-project-number
# Enable Google Picker endpoint (Drive/Photos Picker)
# COMPANION_ENABLE_GOOGLE_PICKER_ENDPOINT=true

# --- OneDrive ---
# Console: https://portal.azure.com/
# Redirect URI: http://localhost:3020/{brand}/connect/onedrive/callback
# COMPANION_ONEDRIVE_KEY=your-onedrive-client-id
# COMPANION_ONEDRIVE_SECRET=your-onedrive-client-secret

# --- Box ---
# Console: https://app.box.com/developers/console
# Redirect URI: http://localhost:3020/{brand}/connect/box/callback
# COMPANION_BOX_KEY=your-box-client-id
# COMPANION_BOX_SECRET=your-box-client-secret

# --- Unsplash ---
# Console: https://unsplash.com/oauth/applications
# COMPANION_UNSPLASH_KEY=your-unsplash-access-key
# COMPANION_UNSPLASH_SECRET=your-unsplash-secret-key

# --- Zoom ---
# Console: https://marketplace.zoom.us/develop/create
# Redirect URI: http://localhost:3020/{brand}/connect/zoom/callback
# COMPANION_ZOOM_KEY=your-zoom-client-id
# COMPANION_ZOOM_SECRET=your-zoom-client-secret

# ===========================================
# BRAND CONFIGURATION (JSON)
# ===========================================
# Set the brand configuration in the .env file as an UPPERCASE env var.
# The env var name is derived from the brand slug:
# - normalize slug (lowercase, trim, replace non [a-z0-9-] with '-')
# - replace '-' with '_' and uppercase
#
# The first brand listed in COMPANION_BRANDS is the DEFAULT brand.
# Full Example for another-brand (-> ANOTHER_BRAND):
# ANOTHER_BRAND='{
#   "auth": {
#     "url": "http://localhost:3000/api/user",
#     "cookieName": "session"
#   },
#   "companionUrl": "https://companion.example.com",
#   "public": {
#     "backendUrl": "http://localhost:3000",
#     "uploadUrl": "http://localhost:3000/api/frame/contents/upload/public"
#   },
#   "corsOrigins": ["https://app.example.com"],
#   "uploadUrls": ["https://my-bucket.s3.amazonaws.com"],
#   "s3": {
#     "bucket": "my-bucket",
#     "region": "us-east-1",
#     "accessKey": "AKIA...",
#     "secretKey": "SECRET...",
#     "useAccelerateEndpoint": false
#   },
#   "providers": {
#     "google": {
#       "clientId": "...",
#       "clientSecret": "...", # OAuth classic (non-picker) flows
#       "driveApiKey": "...",
#       "photosApiKey": "...",
#       "appId": "..."
#     },
#     "dropbox": { "key": "...", "secret": "..." },
#     "facebook": { "key": "...", "secret": "..." },
#     "instagram": { "key": "...", "secret": "..." },
#     "onedrive": { "key": "...", "secret": "..." },
#     "box": { "key": "...", "secret": "..." },
#     "unsplash": { "key": "...", "secret": "..." },
#     "zoom": { "key": "...", "secret": "..." }
#   }
# }'