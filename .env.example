# ===========================================
# COMPANION PLATFORM - Environment Variables
# ===========================================

# Server Configuration
COMPANION_PORT=3020
COMPANION_BIND_HOST=0.0.0.0
# COMPANION_HOST is the *public* hostname the browser uses to reach Companion.
# It MUST share a registrable suffix with the brand's rootDomain (below) so the
# brand session cookie (Domain=.<rootDomain>) is sent to Companion as same-site.
# Local dev with a custom domain (recommended): add "127.0.0.1 companion.abeduls.local"
# to your /etc/hosts (or C:\Windows\System32\drivers\etc\hosts on Windows) and use:
COMPANION_HOST=companion.abeduls.local:3020
# Plain localhost works only if NO rootDomain is configured (auth disabled mode).
# COMPANION_HOST=localhost:3020
COMPANION_PROTOCOL=http
COMPANION_SECRET=your-secret-at-least-16-chars

# File storage
COMPANION_FILE_PATH=/tmp/

# Health check key (gates the detailed /api/brands view)
HEALTH_CHECK_KEY=your-secret-health-check-key

# Redis (shared state: readiness checks now; sessions/breaker/rate-limit in
# later phases). In production this is provided by Railway's Redis plugin —
# do not set it by hand there. Defaults to a local dev instance if omitted.
# REDIS_URL=redis://localhost:6379

# ===========================================
# PER-BRAND SECRETS (Fase 6 — src/lib/secrets.ts#loadBrandSecrets)
# ===========================================
# Brands themselves are declared in code (src/modules/brand/registry.ts) and
# resolved as: base registry -> <SLUG>_BRAND_OVERRIDE (auth fields only, see
# identity.ts) -> per-brand secrets loaded per the scheme below. There is no
# COMPANION_BRANDS CSV or per-brand JSON blob to set — see "COMPANION_BRANDS"
# / "BRAND CONFIGURATION (JSON)" further down for reference only; both are
# retired and read by nothing anymore.
#
# SECRETS_SOURCE selects HOW every brand's S3 credentials + OAuth provider
# secrets are loaded (brand-independent switch; default "env"):
SECRETS_SOURCE=env
# SECRETS_SOURCE=aws

# --- SECRETS_SOURCE=env (default) ---
# Plain process env vars, one set per brand, keyed by an env-var PREFIX
# derived from the brand slug: uppercase it and replace "-" with "_"
# (e.g. slug "edo" -> prefix "EDO"). IN PRODUCTION these are Railway
# *service variables* configured per-service in the Railway dashboard — they
# are never committed and never live in a shared .env file on the server.
#
# S3 (bucket/region fall back to the code-only base registry when unset;
# access/secret key are REQUIRED under SECRETS_SOURCE=env — Railway has no
# instance IAM role to fall back to):
# <PREFIX>_S3_ACCESS_KEY=AKIA...
# <PREFIX>_S3_SECRET_KEY=...
# <PREFIX>_S3_BUCKET=...
# <PREFIX>_S3_REGION=us-east-1
# <PREFIX>_S3_ACCELERATE_ENDPOINT=false
#
# Example for the "edo" brand:
# EDO_S3_ACCESS_KEY=AKIA...
# EDO_S3_SECRET_KEY=...
# EDO_S3_BUCKET=entourage-uploads
# EDO_S3_REGION=us-east-1
#
# OAuth providers (all optional; a provider is only wired once BOTH _KEY and
# _SECRET are set for it):
# <PREFIX>_DROPBOX_KEY / <PREFIX>_DROPBOX_SECRET
# <PREFIX>_FACEBOOK_KEY / <PREFIX>_FACEBOOK_SECRET
# <PREFIX>_INSTAGRAM_KEY / <PREFIX>_INSTAGRAM_SECRET
# <PREFIX>_ONEDRIVE_KEY / <PREFIX>_ONEDRIVE_SECRET
# <PREFIX>_BOX_KEY / <PREFIX>_BOX_SECRET
# <PREFIX>_UNSPLASH_KEY / <PREFIX>_UNSPLASH_SECRET
# <PREFIX>_ZOOM_KEY / <PREFIX>_ZOOM_SECRET
#
# Google (wired once <PREFIX>_GOOGLE_CLIENT_ID is set; the rest are optional):
# <PREFIX>_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# <PREFIX>_GOOGLE_CLIENT_SECRET=GOCSPX-...   # classic OAuth flows only
# <PREFIX>_GOOGLE_DRIVE_API_KEY=AIzaSy...    # Drive Picker
# <PREFIX>_GOOGLE_PHOTOS_API_KEY=AIzaSy...   # Photos Picker
# <PREFIX>_GOOGLE_APP_ID=...
#
# --- SECRETS_SOURCE=aws (optional) ---
# Reads one JSON secret per brand from AWS Secrets Manager instead of plain
# env vars. `@aws-sdk/client-secrets-manager` is loaded via a dynamic
# import() and is NEVER pulled in under the default SECRETS_SOURCE=env.
# SECRETS_MANAGER_REGION=us-east-1        # falls back to AWS_REGION, then us-east-1
# <PREFIX>_SECRETS_ID=companion/edo       # falls back to "companion/<slug>"
#
# The secret's SecretString must be JSON shaped like:
# {
#   "s3": {
#     "accessKey": "AKIA...", "secretKey": "...",
#     "bucket": "...", "region": "us-east-1", "useAccelerateEndpoint": false
#   },
#   "providers": {
#     "google": { "clientId": "...", "clientSecret": "...", "driveApiKey": "...", "photosApiKey": "...", "appId": "..." },
#     "dropbox": { "key": "...", "secret": "..." }
#     // ...facebook / instagram / onedrive / box / unsplash / zoom, same {key, secret} shape
#   }
# }
# Every field is optional; a missing bucket/region falls back to the
# code-only base registry, same as the env source. Unlike the env source,
# missing S3 credentials are NOT a fail-fast error under aws — the AWS SDK's
# Default Credential Provider Chain (IAM role) applies. The whole cache is
# warmed ONCE at process boot (top-level await in secrets.ts) before the
# brand registry is built.

# ===========================================
# LEGACY (retired by the abeduls3-alignment cutover — kept for reference only,
# read by nothing): CSV brand list + per-brand JSON config blob.
# ===========================================
# Brands (comma-separated slugs)
# The first brand listed is the DEFAULT brand.
COMPANION_BRANDS=abeduls

# ===========================================
# PER-BRAND AUTHENTICATION
# ===========================================
# URL that validates tokens. Returns 200 + user JSON if authenticated.
# DEFAULT_AUTH_URL=https://api.example.com/api/user

# ===========================================
# AWS S3 CONFIGURATION
# ===========================================
AWS_BUCKET_NAME=your-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# COMPANION_AWS_ACCELERATE_ENDPOINT=false

# ===========================================
# OAUTH PROVIDERS
# ===========================================

# --- Dropbox ---
# Console: https://www.dropbox.com/developers/apps
# Redirect URI: http://localhost:3020/{brand}/connect/dropbox/callback
COMPANION_DROPBOX_KEY=your-dropbox-app-key
COMPANION_DROPBOX_SECRET=your-dropbox-app-secret

# --- Facebook / Instagram ---
# Console: https://developers.facebook.com/apps/
# Redirect URIs: 
#   http://localhost:3020/{brand}/connect/facebook/callback
#   http://localhost:3020/{brand}/connect/instagram/callback
COMPANION_FACEBOOK_KEY=your-facebook-app-id
COMPANION_FACEBOOK_SECRET=your-facebook-app-secret

# --- Google Drive / Google Photos ---
# Console: https://console.cloud.google.com/
# Enable: Google Drive API, Google Photos Library API
# Redirect URI: http://localhost:3020/{brand}/connect/google/callback
COMPANION_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
COMPANION_GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# Picker credentials (public)
COMPANION_GOOGLE_DRIVE_API_KEY=AIzaSyour-google-drive-picker-api-key
COMPANION_GOOGLE_PHOTOS_API_KEY=AIzaSyour-google-photos-picker-api-key
COMPANION_GOOGLE_APP_ID=your-google-project-number
# Enable Google Picker endpoint (Drive/Photos Picker)
# COMPANION_ENABLE_GOOGLE_PICKER_ENDPOINT=true

# --- OneDrive ---
# Console: https://portal.azure.com/
# Redirect URI: http://localhost:3020/{brand}/connect/onedrive/callback
# COMPANION_ONEDRIVE_KEY=your-onedrive-client-id
# COMPANION_ONEDRIVE_SECRET=your-onedrive-client-secret

# --- Box ---
# Console: https://app.box.com/developers/console
# Redirect URI: http://localhost:3020/{brand}/connect/box/callback
# COMPANION_BOX_KEY=your-box-client-id
# COMPANION_BOX_SECRET=your-box-client-secret

# --- Unsplash ---
# Console: https://unsplash.com/oauth/applications
# COMPANION_UNSPLASH_KEY=your-unsplash-access-key
# COMPANION_UNSPLASH_SECRET=your-unsplash-secret-key

# --- Zoom ---
# Console: https://marketplace.zoom.us/develop/create
# Redirect URI: http://localhost:3020/{brand}/connect/zoom/callback
# COMPANION_ZOOM_KEY=your-zoom-client-id
# COMPANION_ZOOM_SECRET=your-zoom-client-secret

# ===========================================
# BRAND CONFIGURATION (JSON)
# ===========================================
# Set the brand configuration in the .env file as an UPPERCASE env var.
# The env var name is derived from the brand slug:
# - normalize slug (lowercase, trim, replace non [a-z0-9-] with '-')
# - replace '-' with '_' and uppercase
#
# The first brand listed in COMPANION_BRANDS is the DEFAULT brand.
# Full Example for another-brand (-> ANOTHER_BRAND):
# ANOTHER_BRAND='{
#   "rootDomain": "another-brand.com",
#   "auth": {
#     "url": "http://localhost:3000/api/user",
#     "cookieName": "session"
#   },
#   "companionUrl": "https://companion.example.com",
#   "public": {
#     "backendUrl": "http://localhost:3000",
#     "uploadUrl": "http://localhost:3000/api/frame/contents/upload/public",
#     "foldersUrl": "http://localhost:3000/api/folders",
#     "loginUrl": "https://dashboard.another-brand.com/login"
#   },
#   "corsOrigins": ["https://app.example.com"],
#   "uploadUrls": ["https://my-bucket.s3.amazonaws.com"],
#   "s3": {
#     "bucket": "my-bucket",
#     "region": "us-east-1",
#     "accessKey": "AKIA...",
#     "secretKey": "SECRET...",
#     "useAccelerateEndpoint": false
#   },
#   "providers": {
#     "google": {
#       "clientId": "...",
#       "clientSecret": "...", # OAuth classic (non-picker) flows
#       "driveApiKey": "...",
#       "photosApiKey": "...",
#       "appId": "..."
#     },
#     "dropbox": { "key": "...", "secret": "..." },
#     "facebook": { "key": "...", "secret": "..." },
#     "instagram": { "key": "...", "secret": "..." },
#     "onedrive": { "key": "...", "secret": "..." },
#     "box": { "key": "...", "secret": "..." },
#     "unsplash": { "key": "...", "secret": "..." },
#     "zoom": { "key": "...", "secret": "..." }
#   },
#   "enabledPlugins": "Url,GoogleDrivePicker,GooglePhotosPicker,Dropbox"
# }'
#
# ===========================================
# LOCAL DEV EXAMPLE: abeduls.local
# ===========================================
# Concrete config for the "abeduls" brand running under a custom local domain.
# Prerequisites:
#   1. Add to /etc/hosts (or C:\Windows\System32\drivers\etc\hosts):
#        127.0.0.1 abeduls.local
#        127.0.0.1 app.abeduls.local
#        127.0.0.1 api.abeduls.local
#        127.0.0.1 companion.abeduls.local
#   2. Set COMPANION_HOST=companion.abeduls.local:3020 (above) so OAuth
#      redirect URIs are derived from a host the browser can resolve.
#   3. Your brand backend (e.g. Laravel at api.abeduls.local) must set its
#      session cookie with Domain=.abeduls.local, HttpOnly, SameSite=Lax.
#      Secure is NOT required in dev (COMPANION_PROTOCOL=http) but the
#      brand backend may still set it — Chrome accepts Secure on http://
#      origins under registrable suffixes used in /etc/hosts only when the
#      cookie is set on the same plain-HTTP origin. Easiest: omit Secure
#      in dev only.
#   4. Run `npx tsx scripts/verify-brand-config.ts` after editing — it must
#      exit 0 and confirm rootDomain is set.
#
# Uncomment and fill in the secrets/keys appropriate for your local setup.
# Note: Google Picker requires real API keys even in dev — providers you
# don't use locally can be omitted from `enabledPlugins`.
#
# ABEDULS='{
#   "displayName": "Abeduls (local dev)",
#   "rootDomain": "abeduls.local",
#   "auth": {
#     "url": "http://api.abeduls.local/api/user",
#     "cookieName": "abeduls_session"
#   },
#   "companionUrl": "http://companion.abeduls.local:3020",
#   "public": {
#     "backendUrl": "http://api.abeduls.local",
#     "uploadUrl": "http://api.abeduls.local/api/frame/contents/upload/public",
#     "foldersUrl": "http://api.abeduls.local/api/folders",
#     "loginUrl": "http://app.abeduls.local/login"
#   },
#   "s3": {
#     "bucket": "abeduls-dev",
#     "region": "us-east-1",
#     "accessKey": "AKIA...",
#     "secretKey": "..."
#   },
#   "enabledPlugins": "Url,GoogleDrivePicker"
# }'
#
# ===========================================
# rootDomain & public.loginUrl (cookie auth)
# ===========================================
# rootDomain: Required when auth.url is set. The registrable domain
# the brand backend issues its session cookie under (Domain=.<rootDomain>).
# Companion uses this to (a) build the per-brand CORS allowlist for
# /api/uppy/* (any *.<rootDomain> origin is allowed in production
# over HTTPS only) and (b) document the cookie scope expectation.
#
# public.loginUrl: Optional. Where Companion 302's the user when the
# brand session cookie is missing or invalid. Receives ?redirect=<full
# url> back to /uppy. The dashboard MUST validate the redirect target
# against an allow-list (e.g. only redirect to https://companion.<root>)
# to avoid open-redirect abuse.
#
# ===========================================
# OPERATOR PRE-DEPLOY CHECKLIST (do these BEFORE rolling this version)
# ===========================================
# 1. Brand backend session cookie must be set with:
#      Domain=.<rootDomain>   (e.g. Domain=.abeduls.com)
#      HttpOnly
#      Secure (in production)
#      SameSite=Lax
#    Laravel example: config/session.php
#      'domain' => '.abeduls.com',
#      'secure' => true,
#      'http_only' => true,
#      'same_site' => 'lax',
#    Verify with: curl -i https://api.<rootDomain>/login -d ...
#    and inspect the Set-Cookie header.
#
# 2. CORS on every brand backend endpoint the Uppy page calls
#    cross-origin (currently publicUploadUrl; foldersUrl is server-to-server
#    from Companion and does not need CORS):
#      Access-Control-Allow-Origin: <echo request Origin if it matches
#                                    https://*.<rootDomain> in production;
#                                    http:// allowed only for explicit
#                                    local/dev origins>
#      Access-Control-Allow-Credentials: true
#      Access-Control-Allow-Methods: GET, POST, OPTIONS
#      Access-Control-Allow-Headers: Content-Type
#      OPTIONS preflight returns 204 (or 200) with the headers above.
#
#    DO NOT echo http:// origins in production. The brand session cookie has
#    Secure and travels because the request URL is HTTPS, so allowing an
#    http:// origin under the brand root with Allow-Credentials would let an
#    HTTP attacker page read credentialed responses — the same vulnerability
#    Companion's CORS rule closes on the upload-API side.
#
# 3. Dashboard's loginUrl endpoint must accept ?redirect=<url> and validate
#    the redirect target against an allow-list (e.g. only redirect to URLs
#    starting with https://companion.<rootDomain>) to prevent open-redirect
#    abuse. This is the dashboard's responsibility — Companion only constructs
#    the URL; it does not validate.
#
# 4. Run before deploy:
#      npx tsx scripts/verify-brand-config.ts
#    Must exit 0. Will fail if any brand has auth.url without rootDomain.
#
# Full design rationale: docs/superpowers/specs/2026-04-29-cookie-only-cross-origin-auth-design.md
#
# ===========================================
# AVAILABLE UPPY PLUGINS (for enabledPlugins)
# ===========================================
# Use these names in the enabledPlugins field (case-insensitive):
#
# - Url                 : Import from URL
# - GoogleDrivePicker   : Google Drive Picker (recommended)
# - GooglePhotosPicker  : Google Photos Picker (recommended)
# - GoogleDrive         : Google Drive OAuth (legacy)
# - GooglePhotos        : Google Photos OAuth (legacy)
# - Dropbox             : Dropbox
# - Facebook            : Facebook
# - Instagram           : Instagram
# - OneDrive            : Microsoft OneDrive
# - Box                 : Box.com
# - Unsplash            : Unsplash stock photos
# - Zoom                : Zoom recordings
#
# Example: "enabledPlugins": "Url,GoogleDrivePicker,Dropbox"